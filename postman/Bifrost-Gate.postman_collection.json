{
  "info": {
    "_postman_id": "7c7d0a2f-8d43-4f80-84e0-6b2238a2f100",
    "name": "Bifrost-Gate API",
    "description": "Collection to test Bifrost-Gate service endpoints with API key auth.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Topology",
      "item": [
        {
          "name": "Get Topology",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response has nodes and edges', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('nodes');",
                  "  pm.expect(json).to.have.property('edges');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{apiKey}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/topology",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "topology"
              ]
            },
            "description": "Returns the current VPN topology. Requires a valid API key."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Metrics",
      "item": [
        {
          "name": "Get Prometheus Metrics",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response is text/plain', function () {",
                  "  pm.expect(pm.response.headers.get('Content-Type')).to.include('text/plain');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
