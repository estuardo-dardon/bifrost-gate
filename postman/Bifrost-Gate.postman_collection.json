  "item": [
    {
      "name": "Topology",
      "item": [
        {
          "name": "Get Topology",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response has nodes and edges', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('nodes');",
                  "  pm.expect(json).to.have.property('edges');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{apiKey}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/topology",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "topology"
              ]
            },
            "description": "Returns the current VPN topology. Requires a valid API key."
          },
          "response": []
        }
      ]
    },
