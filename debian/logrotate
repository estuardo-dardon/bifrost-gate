/var/log/bifrost-service-access.log /var/log/bifrost-service-error.log /var/log/bifrost-worker.log {
    daily
    rotate 14
    compress
    delaycompress
    missingok
    notifempty
    create 0640 root root
    sharedscripts
    postrotate
        systemctl reload-or-restart bifrost-gate > /dev/null 2>&1 || true
    endscript
}
